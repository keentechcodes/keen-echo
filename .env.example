# keen-echo — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# GCP Deployment (used by deploy_gcp.sh)
# ============================================================

# Your GCP project ID (from Google Cloud Console)
GCP_PROJECT_ID="your-gcp-project-id"

# GCP region — us-central1 has L4 GPU availability
GCP_REGION="us-central1"

# Cloud Storage bucket name for model files
GCS_BUCKET_NAME="your-model-bucket"

# Cloud Run service name
SERVICE_NAME="your-bot"

# Directory name of your model inside the GCS bucket
# This should match the directory you uploaded (e.g., my-model-merged)
MODEL_PATH="my-model-merged"

# ============================================================
# Chat UI (referenced in index.html — edit there directly)
# ============================================================

# These are set as JS constants in index.html, not read from .env:
#   MODEL_NAME  — must match MODEL_PATH above
#   SYSTEM_PROMPT — your persona description
