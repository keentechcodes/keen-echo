# keen-echo — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# GCP Deployment (used by deploy_gcp.sh)
# ============================================================

# Your GCP project ID (from Google Cloud Console)
GCP_PROJECT_ID="your-gcp-project-id"

# GCP region — us-central1 has L4 GPU availability
GCP_REGION="us-central1"

# Cloud Run service name
SERVICE_NAME="your-bot"

# ============================================================
# Model Source — Choose ONE of these two options:
# ============================================================

# Option A: HuggingFace (simpler — vLLM pulls the model directly)
# Set this to your HuggingFace model ID (e.g., "username/my-model")
# Leave empty or commented out to use GCS instead.
HF_MODEL_ID=""

# Option B: Google Cloud Storage (upload model to a bucket first)
# Only used when HF_MODEL_ID is empty.
GCS_BUCKET_NAME="your-model-bucket"
MODEL_PATH="my-model-merged"
